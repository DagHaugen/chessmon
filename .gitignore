# Python
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/

# Virtual environment (recreate with: python -m venv .venv && pip install -r requirements.txt)
.venv/

# Generated renders / scratch output
out/

# Live-game runtime state
live.json

# Server-console device registry (persisted names) — runtime state
devices.json

# Registries + game archive (runtime data; formats reseed from code, the rest are user-created)
formats.json
players.json
tournaments.json
games.json

# Persisted live sessions (calibrated boards + games) — survives a server restart
sessions.pkl

# Self-signed TLS cert for the camera PWA (generated by server/serve_https.py)
cert.pem
key.pem
dev.cer
chessmon-ca.pem
chessmon-ca-key.pem

# Stockfish binary (auto-downloaded by setup) + cloud broadcast config (holds the event key)
/server/engines/
cloud.json
broadcast.bat

# WebRTC phase-4 device PWA bundle (output of webrtc/build_app.py)
/webrtc/dist/

# OS cruft
Thumbs.db
.DS_Store

# Local Claude Code overrides (launch.json is intentionally tracked)
.claude/settings.local.json
